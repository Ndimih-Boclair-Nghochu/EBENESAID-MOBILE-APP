{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ]
    },
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true
  },
  "include": [
    "app",
    "src",
    "app.config.ts",
    "expo-env.d.ts"
  ]
}

